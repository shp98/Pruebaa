            local container = tabContent:FindFirstChild("TabScroller")
            textBox.Parent = container or tabContent
            textBox.PlaceholderText = placeholder
            textBox.ZIndex = textBox.ZIndex + windowCounter * 10
            
            local textBoxRoundify = textBox:GetChildren()[1]
            textBoxRoundify.ZIndex = textBoxRoundify.ZIndex + windowCounter * 10
            textBoxRoundify.ImageTransparency = config.title_bar_transparency or 0
            applyGradient(textBoxRoundify, config.title_bar, 0)
            textBox.TextColor3 = Color3.new(1, 1, 1)
            textBox.PlaceholderColor3 = Color3.fromRGB(200, 200, 200)
            
            textBox.FocusLost:Connect(function(enterPressed)
                if enterPressed and #textBox.Text > 0 then
                    pcall(callback, textBox.Text)
                    if options.clear then
                        textBox.Text = ""
                    end
                end
            end)
            
            return textBox
        end
        
        -- Continuaría con AddSlider, AddKeybind, AddDropdown, AddColorPicker, etc.
        -- (similar a la estructura anterior pero con nombres legibles)
        
        return tabObject, tabContent
    end
    
    return windowObject, window
end

-- Limpiar conexiones cuando el script se destruya
script.AncestryChanged:Connect(function()
    if not script.Parent then
        clearConnections()
    end
end)

-- Retornar el módulo
return UIModule
