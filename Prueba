-- Función de animación/tween
local function tweenObject(object, properties, duration)
    duration = duration or 0.1
    if duration == 0 then
        for property, value in pairs(properties) do
            object[property] = value
        end
        return
    end
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = tweenService:Create(object, tweenInfo, properties)
    tween:Play()
    return tween
end

-- Función para aplicar gradiente a un objeto
local function applyGradient(object, colors, rotation)
    local existingGradient = object:FindFirstChild("UIGradient")
    if existingGradient then
        existingGradient:Destroy()
    end
    
    if type(colors) == "Color3" then
        colors = {colors}
    end
    
    if not colors or #colors == 0 then
        return
    end
    
    if #colors == 1 then
        if object:IsA("ImageLabel") or object:IsA("ImageButton") then
            object.ImageColor3 = colors[1]
        else
            object.BackgroundColor3 = colors[1]
        end
        return
    end
    
    local gradient = Instance.new("UIGradient")
    gradient.Parent = object
    gradient.Rotation = rotation or 0
    
    local keypoints = {}
    if #colors == 2 then
        keypoints = {
            ColorSequenceKeypoint.new(0, colors[1]),
            ColorSequenceKeypoint.new(1, colors[2])
        }
    elseif #colors >= 3 then
        keypoints = {
            ColorSequenceKeypoint.new(0, colors[1]),
            ColorSequenceKeypoint.new(0.5, colors[2]),
            ColorSequenceKeypoint.new(1, colors[3])
        }
    end
    
    gradient.Color = ColorSequence.new(keypoints)
    
    if object:IsA("ImageLabel") or object:IsA("ImageButton") then
        object.ImageColor3 = Color3.new(1, 1, 1)
    else
        object.BackgroundColor3 = Color3.new(1, 1, 1)
    end
end

-- Función para convertir RGB a HSV
local function rgbToHsv(r, g, b)
    r, g, b = r / 255, g / 255, b / 255
    local max, min = math.max(r, g, b), math.min(r, g, b)
    local h, s, v = 0, 0, max
    local delta = max - min
    s = (max == 0) and 0 or delta / max
    
    if max ~= min then
        if max == r then
            h = (g - b) / delta + (g < b and 6 or 0)
        elseif max == g then
            h = (b - r) / delta + 2
        elseif max == b then
            h = (r - g) / delta + 4
        end
        h = h / 6
    end
    
    return h, s, v
end

