        -- Efecto de partículas para la pestaña seleccionada
        local function createParticleEffect(button)
            if button ~= currentTab then return end
            
            local size = button.AbsoluteSize
            for i = 1, 3 do
                task.spawn(function()
                    local particle = Instance.new("Frame")
                    particle.Name = "SimpleParticle"
                    particle.Size = UDim2.new(0, 1.5, 0, 1.5)
                    particle.AnchorPoint = Vector2.new(0.5, 0.5)
                    particle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                    particle.BorderSizePixel = 0
                    particle.ZIndex = button.ZIndex + 15
                    
                    local particleCorner = Instance.new("UICorner")
                    particleCorner.CornerRadius = UDim.new(1, 0)
                    particleCorner.Parent = particle
                    
                    local direction = math.random(1, 4)
                    local startX, startY = 0, 0
                    
                    if direction == 1 then
                        startX = math.random(5, size.X - 5)
                        startY = 1
                    elseif direction == 2 then
                        startX = size.X - 1
                        startY = math.random(5, size.Y - 5)
                    elseif direction == 3 then
                        startX = math.random(5, size.X - 5)
                        startY = size.Y - 1
                    else
                        startX = 1
                        startY = math.random(5, size.Y - 5)
                    end
                    
                    particle.Position = UDim2.new(0, startX, 0, startY)
                    particle.Parent = button
                    
                    local centerX, centerY = size.X / 2, size.Y / 2
                    local diffX, diffY = startX - centerX, startY - centerY
                    local distance = math.sqrt(diffX * diffX + diffY * diffY)
                    diffX, diffY = diffX / distance, diffY / distance
                    
                    local endX = startX + diffX * 6
                    local endY = startY + diffY * 6
                    
                    local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                    local tween = tweenService:Create(particle, tweenInfo, {
                        Position = UDim2.new(0, endX, 0, endY),
                        BackgroundTransparency = 1
                    })
                    tween:Play()
                    
                    task.wait(0.5)
                    if particle and particle.Parent then
                        particle:Destroy()
                    end
                end)
            end
        end
        
        -- Función para mantener el efecto de partículas mientras la pestaña está activa
