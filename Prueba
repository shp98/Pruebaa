-- Efecto de ripple al hacer clic
local function createRippleEffect(parent, clickX, clickY)
    task.spawn(function()
        parent.ClipsDescendants = true
        local ripple = prefabs:FindFirstChild("Circle"):Clone()
        ripple.Parent = parent
        ripple.ZIndex = 1000
        
        local relativeX = clickX - ripple.AbsolutePosition.X
        local relativeY = clickY - ripple.AbsolutePosition.Y
        ripple.Position = UDim2.new(0, relativeX, 0, relativeY)
        
        local maxSize = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.5
        ripple:TweenSizeAndPosition(
            UDim2.new(0, maxSize, 0, maxSize),
            UDim2.new(0.5, -maxSize / 2, 0.5, -maxSize / 2),
            Enum.EasingDirection.Out,
            Enum.EasingStyle.Quad,
            0.5,
            false
        )
        
        tweenObject(ripple, { ImageTransparency = 1 }, 0.5)
        task.wait(0.5)
        ripple:Destroy()
    end)
end

